{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/index.ts", "src/test-helper/index.ts"],
  "project": ["src/**/*.ts"],
  "bun": false,
  "github-actions": false,
  "node": false,
  "taskfile": false,
  "typescript": false,
  "rules": {
    "files": "error",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "duplicates": "off",
    "devDependencies": "off",
    "optionalPeerDependencies": "off",
    "binaries": "off",
    "enumMembers": "off"
  }
}
